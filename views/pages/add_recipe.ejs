<!DOCTYPE html>
<html>
    <%- include('../partials/header', {activePage:'add-recipe'}) %>
        <body>
            <main>
                <form action="/add-recipe" method="POST">
                    <h2>Add a Recipe</h2>

                    <label>Recipe Name</label>
                    <input type="text" name="name" maxlength="31" required>

                    <label>Category (Protein)</label>
                    <input type="text" name="protein" maxlength="31" required>

                    <label>Cook Time (minutes)</label>
                    <input type="number" name="cook_time" required>

                    <label>Initial Cost ($)</label>
                    <input type="number" name="init_cost" step="0.01" required>

                    <label>Cost Per Serving ($)</label>
                    <input type="number" name="serving_cost" step="0.01" required>

                    <label>Instructions</label>
                    <textarea name="instructions" placeholder="Each new line will become a step..."></textarea>

                    <h3>Ingredients</h3>
                    <div id="ingredient-rows">
                        <div class="ingredient-row">
                            <select name="ingredient_id[]">
                                <option value="">-- Select Ingredient --</option>
                                <% ingredients.forEach(i => { %>
                                    <option value="<%= i.id %>"><%= i.name %></option>
                                <% }); %>
                            </select>
                            <input type="text" name="quantity[]" placeholder="e.g. 2 Tbsp" maxlength="31">
                        </div>
                    </div>

                    <button type="button" onclick="addRow()">+ Add Ingredient</button>
                    <br><br>
                    <button type="submit">Submit Recipe</button>
                </form>
            </main>
        </body>

        <script>
            function addRow() {
                const container = document.getElementById("ingredient-rows");
                const first = container.querySelector(".ingredient-row");
                const newRow = first.cloneNode(true);
                // Reset the cloned row's values
                newRow.querySelector("select").value = "";
                newRow.querySelector("input").value = "";
                container.appendChild(newRow);
            }
        </script>

    <%- include('../partials/footer') %>
</html>